pipeline{
    agent {label 'jenkins-agent'}
    tools {
        maven 'Maven3'
    }
    options {
        timeout(time: 5, unit: 'MINUTES')
        timestamps()
    }
    environment {
        APP_DIR = "/home/ubuntu/Devops_Trainning/CICD/spring-boot-jenkins-demo"
        JAVA_HOME = "/usr/lib/jvm/java-21-openjdk-amd64"
        PROJECT_NAME = "spring-boot-app-demo_for_cicd"
        DOCKER_USER = "ducng17"
        DOCKER_PASS = "dockerhub"
        IMAGE_NAME = "${DOCKER_USER}/${PROJECT_NAME}"
        VERSION = "1.0.0"
        IMAGE_TAG = "${VERSION}-${BUILD_NUMBER}" 
        JENKINS_API_TOKEN= credentials("JENKINS_API_TOKEN")
    }
    stages{
        stage("Clean up"){
            steps {
                cleanWs()
            }
        }
        stage("Check out src"){
            steps {
                git branch: 'main', credentialsId: 'github', url: 'https://github.com/ducnguyen1707/Devops_Trainning.git'
            }
        }
        stage("Start Database"){
            steps {
                sh "cd ${APP_DIR} && docker-compose up -d"
                sh "cd ${APP_DIR} && docker-compose ps"
            }
        }
        stage("Build Application"){
            steps {
                sh "cd ${APP_DIR} && mvn clean package"
            }
        }
        stage("Run Tests"){
            steps {
                sh "cd ${APP_DIR} && mvn test -q"
            }
        }
        stage("Sonar Scan"){
            steps{
                script{
                    // Use dir instead of cd 
                    dir("${APP_DIR}") {
                    withSonarQubeEnv(credentialsId: 'jenkins-sonarqube-token'){
                        sh "mvn sonar:sonar"
                        }
                    }
                }
            }
        }
        stage("Quality gate"){
            steps{
                script{
                    waitForQualityGate abortPipeline: false, credentialsId: 'jenkins-sonarqube-token'
                }
            }
        }
        stage("Build Project Image and push on Docker HUB"){
            steps {
                script {
                    dir("${APP_DIR}") {
                        docker.withRegistry('', DOCKER_PASS) {
                            def docker_image = docker.build("${IMAGE_NAME}")
                            docker_image.push("${IMAGE_TAG}")
                            docker_image.push("latest")
                        }
                    }
                }
            }
        }
        stage("Trivy scan"){
            steps{
                script {
                    // --exit-code 1 if want pipeline fail after found cve
                    sh ("docker run -v /var/run/docker.sock:/var/run/docker.sock aquasec/trivy image ducng17/spring-boot-app-demo_for_cicd:latest --no-progress --scanners vuln --exit-code 0 --severity HIGH,CRITICAL --format table")
                }
            }
        }
        stage("CD Trigg"){
            steps{
                script{
                    sh "curl -v -k --user admin:${JENKINS_API_TOKEN} -X POST -H 'cache-control: no-cache' -H 'content-type: application/x-www-form-urlencoded' --data 'IMAGE_TAG=${IMAGE_TAG}' 'ec2-13-232-128-192.ap-south-1.compute.amazonaws.com:8080/job/gitops-register-app-cd/buildWithParameters?token=gitops-token'"
                }
            }
        }
        stage("Cleanup") {
            steps {
                script {
                        sh "docker rmi ${IMAGE_NAME}:${IMAGE_TAG}"
                        sh "docker rmi ${IMAGE_NAME}:latest"
                        sh "docker rm -f \$(docker ps -aq --filter name=spring-boot-app) || true"
                        sh "docker rm -f \$(docker ps -aq --filter ancestor=aquasec/trivy) || true"
                        sh "docker rmi -f aquasec/trivy || true"
                }
            }
        }
    post {
        always {
            sh "cd ${APP_DIR} && docker-compose down -v || true"
        }
        success {
            echo "Pipeline completed successfully!"
        }
        failure {
            echo "Pipeline failed! Check logs above."
        }
    }
        }
    }
}

