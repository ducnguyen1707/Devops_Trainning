pipeline{
    agent {label 'jenkins-agent'}
    tools {
        jdk 'java21'
        maven 'Maven3'
    }
    stages{
        stage("Clean up "){
            steps {
                cleanWs()
            }
        }
        stage("Check out src"){
            steps {
                git branch: 'main', credentialsId: 'github', url: 'https://github.com/ducnguyen1707/Devops_Trainning.git'
            }
        }
        stage("Start DB"){
            steps {
                sh "cd /home/ubuntu/Devops_Trainning/CICD/spring-boot-jenkins-demo && docker compose up -d"
                sh "sleep 20"
            }
        }
        stage("Build"){
            steps {
                sh "cd /home/ubuntu/Devops_Trainning/CICD/spring-boot-jenkins-demo && mvn clean package -DskipTests"
            }
        }
        stage("Test"){
            steps {
                sh "cd /home/ubuntu/Devops_Trainning/CICD/spring-boot-jenkins-demo && mvn test && mvn verify"
            }
        }
    }
}