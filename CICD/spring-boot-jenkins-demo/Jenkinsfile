pipeline{
    agent {label 'jenkins-agent'}
    tools {
        maven 'Maven3'
    }
    options {
        timeout(time: 5, unit: 'MINUTES')
        timestamps()
    }
    environment {
        APP_DIR = "/home/ubuntu/Devops_Trainning/CICD/spring-boot-jenkins-demo"
        JAVA_HOME = "/usr/lib/jvm/java-21-openjdk-amd64"
    }
    stages{
        stage("Clean up"){
            steps {
                cleanWs()
            }
        }
        stage("Check out src"){
            steps {
                git branch: 'main', credentialsId: 'github', url: 'https://github.com/ducnguyen1707/Devops_Trainning.git'
            }
        }
        stage("Verify Docker"){
            steps {
                sh '''
                    docker info
                    docker version
                    docker compose version
                '''
            }
        }
        stage("Start Database"){
            steps {
                sh "cd ${APP_DIR} && docker-compose up -d"
                sh "cd ${APP_DIR} && sleep 15 && docker-compose ps"
            }
        }
        stage("Build Application"){
            steps {
                sh "cd ${APP_DIR} && mvn clean package"
            }
        }
        stage("Run Tests"){
            steps {
                sh "cd ${APP_DIR} && mvn test -q"
            }
        }
        stage("Sonar Scan"){
            steps{
                script{
                    withSonarQubeEnv(credentialsId: 'jenkin-sonar-token') {
                        sh "cd ${APP_DIR} && mvn sonar:sonar -Dsonar.projectKey=spring-boot-app -Dsonar.sources=src/main -Dsonar.tests=src/test"
                    }
                }
            }
        }
        stage("Quality Gate"){
            steps {
                sh "cd ${APP_DIR} && echo 'Waiting for SonarQube Quality Gate result...'"
                script{
                    // Wait for SonarQube Quality Gate result
                    // This ensures code meets minimum quality standards before proceeding
                    // Must be wrapped with withSonarQubeEnv to access SonarQube server details
                    withSonarQubeEnv(credentialsId: 'jenkin-sonar-token') {
                        def qg = waitForQualityGate abortPipeline: false
                        if (qg.status != 'OK') {
                            echo "⚠️  Quality Gate Status: ${qg.status}"
                            echo "Code quality checks failed. Review SonarQube report for details."
                        } else {
                            echo "✅ Quality Gate Status: ${qg.status}"
                            echo "Code passed all quality checks!"
                        }
                    }
                }
            }
        }
        stage("Build Docker Image"){
            steps {
                sh "cd ${APP_DIR} && docker build -t spring-boot-app:latest ."
                sh "docker images | grep spring-boot-app"
            }
        }
        stage("Cleanup"){
            steps {
                sh "cd ${APP_DIR} && docker-compose down"
            }
        }
    }
    post {
        always {
            sh "cd ${APP_DIR} && docker-compose down -v || true"
        }
        success {
            echo "Pipeline completed successfully!"
        }
        failure {
            echo "Pipeline failed! Check logs above."
        }
    }
}