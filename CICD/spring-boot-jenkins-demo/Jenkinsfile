pipeline{
    agent {label 'jenkins-agent'}
    tools {
        maven 'Maven3'
    }
    options {
        timeout(time: 5, unit: 'MINUTES')
        timestamps()
    }
    environment {
        APP_DIR = "/home/ubuntu/Devops_Trainning/CICD/spring-boot-jenkins-demo"
        JAVA_HOME = "/usr/lib/jvm/java-21-openjdk-amd64"
        SONAR_PROJECT_KEY = "spring-boot-app"
        SONAR_SOURCES = "src/main"
        SONAR_TESTS = "src/test"
    }
    stages{
        stage("Clean up"){
            steps {
                cleanWs()
            }
        }
        stage("Check out src"){
            steps {
                git branch: 'main', credentialsId: 'github', url: 'https://github.com/ducnguyen1707/Devops_Trainning.git'
            }
        }
        stage("Verify Docker"){
            steps {
                sh '''
                    docker info
                    docker version
                    docker compose version
                '''
            }
        }
        stage("Start Database"){
            steps {
                sh "cd ${APP_DIR} && docker-compose up -d"
                sh "cd ${APP_DIR} && sleep 15 && docker-compose ps"
            }
        }
        stage("Build Application"){
            steps {
                sh "cd ${APP_DIR} && mvn clean package"
            }
        }
        stage("Run Tests"){
            steps {
                sh "cd ${APP_DIR} && mvn test -q"
            }
        }
        stage("Sonar Scan"){
            steps{
                script{
                    withSonarQubeEnv(credentialsId: 'jenkins-sonarqube-token'){
                        sh "cd ${APP_DIR} && mvn sonar:sonar"
                    }
                }
            }
        }
        stage("Quality gate"){
            steps{
                script{
                    waitForQualityGate abortPipline: false, credentialsId: 'jenkins-sonarqube-token'
                }
            }
        }
        stage("Build Docker Image"){
            steps {
                sh "cd ${APP_DIR} && docker build -t spring-boot-app:latest ."
                sh "docker images | grep spring-boot-app"
            }
        }
        stage("Cleanup") {
            steps {
                script {
                    try {
                        sh "cd ${APP_DIR} && docker-compose down"
                    } catch (Exception e) {
                        echo "docker-compose down failed, trying force cleanup..."
        
                        // Lấy container ID (có thể lọc theo tên nếu cần)
                        def containerId = sh(
                            script: "docker ps -aq --filter name=demo-postgres",
                            returnStdout: true
                        ).trim()
        
                        if (containerId) {
                            echo "Found container: ${containerId}"
        
                            // Lấy PID
                            def pid = sh(
                                script: "docker inspect --format '{{.State.Pid}}' ${containerId}",
                                returnStdout: true
                            ).trim()
        
                            echo "Killing PID: ${pid}"
        
                            // Kill process
                            sh "sudo kill -9 ${pid} || true"
        
                            // Remove container lại
                            sh "docker rm -f ${containerId} || true"
                        } else {
                            echo "No container found"
                        }
                    }
                }
            }
    post {
        always {
            sh "cd ${APP_DIR} && docker-compose down -v || true"
        }
        success {
            echo "Pipeline completed successfully!"
        }
        failure {
            echo "Pipeline failed! Check logs above."
        }
    }
        }
    }
}
